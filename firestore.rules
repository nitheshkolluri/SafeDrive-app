
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is a member (Fast check via parent doc array)
    function isCircleMember(circleId) {
      return isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/safetyCircles/$(circleId)).data.memberIds;
    }

    // Check if user is Admin/Owner (Detailed check)
    function isCircleAdmin(circleId) {
      let role = get(/databases/$(database)/documents/safetyCircles/$(circleId)/members/$(request.auth.uid)).data.role;
      return isAuthenticated() && (role == 'OWNER' || role == 'ADMIN');
    }

    // --- 1. USERS & SUBCOLLECTIONS ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /trips/{tripId} { allow read, write: if isOwner(userId); }
      match /vehicles/{vehicleId} { allow read, write: if isOwner(userId); }
      match /saved_places/{placeId} { allow read, write: if isOwner(userId); }
      match /files/{fileId} { allow read, write: if isOwner(userId); }
      
      // User-specific circle settings (Privacy consents)
      match /circleSettings/{circleId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 2. SAFETY CIRCLES (Canonical) ---
    match /safetyCircles/{circleId} {
      // Create: Anyone
      allow create: if isAuthenticated();
      
      // Read Single: ANY AUTH USER (Required for joining/previewing)
      allow get: if isAuthenticated();
      
      // List: ONLY MEMBERS (Privacy)
      allow list: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.memberIds
      );
      
      // Update: Admin OR Member Join/Leave logic
      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        isCircleAdmin(circleId) ||
        // Atomic Join (Add self to memberIds)
        (request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 && 
         request.auth.uid in request.resource.data.memberIds) ||
        // Atomic Leave (Remove self from memberIds)
        (request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1 && 
         !(request.auth.uid in request.resource.data.memberIds))
      );

      // Delete: Owner or Admin
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isCircleAdmin(circleId));

      // Subcollections
      match /members/{memberUid} {
        allow read: if isCircleMember(circleId);
        // Write: User can update own status (Location toggle), Admin can change roles
        allow write: if isAuthenticated() && (
            request.auth.uid == memberUid || 
            isCircleAdmin(circleId)
        );
      }

      match /invites/{inviteId} {
        allow read, create, delete: if isCircleAdmin(circleId);
      }
      
      match /analytics/{periodId} {
        allow read: if isCircleMember(circleId);
      }
      
      match /events/{eventId} {
        allow read: if isCircleMember(circleId);
        allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.sourceUid || isCircleAdmin(circleId));
      }
    }

    // --- 3. PUBLIC INVITES ---
    match /publicInvites/{token} {
      allow read: if true; // Public read for validation
      allow create, delete: if isAuthenticated(); // Only auth users generate/revoke invites
    }

    // --- 4. FEEDBACK ---
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
    }
    
    // --- 5. LEGACY CIRCLES (Redirect/Block) ---
    match /circles/{circleId} {
        allow read, write: if false; // Deprecated
    }
  }
}
